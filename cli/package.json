{
  "name": "@devlair/cli",
  "version": "2.1.0-alpha.1",
  "description": "Dev machine provisioning CLI — interactive wizards, module groups, enterprise onboarding",
  "type": "module",
  "private": true,
  "bin": {
    "devlair": "dist/cli.js"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outfile dist/cli.js --target node --format esm",
    "compile": "bun build --compile src/index.tsx --outfile dist/devlair",
    "compile:x64": "bun build --compile --target=bun-linux-x64 src/index.tsx --outfile dist/devlair-linux-x86_64",
    "compile:arm64": "bun build --compile --target=bun-linux-arm64 src/index.tsx --outfile dist/devlair-linux-aarch64",
    "test": "bun test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ettoreaquino/devlair.git",
    "directory": "cli"
  }
}
